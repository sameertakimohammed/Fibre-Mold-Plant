# Copy this file to .env and change the values before deploying.
# ---------------------------------------------------------------
# IMPORTANT: in production (APP_ENV=production, the default) the app will
# REFUSE TO START if SECRET_KEY is a known placeholder or shorter than 32
# characters. `docker compose up` will also fail fast if any required
# variable below is missing from .env. This is intentional, fail-closed
# behaviour so the plant never runs on guessable, public-default secrets.

# Environment mode.
#   production  (default) -> enforces strong secrets; app refuses to start on
#                            placeholder/short SECRET_KEY values.
#   development           -> relaxes the hard checks (only warns) so a local
#                            dev box / SQLite can boot freely.
# Leave this as production on the plant PC.
APP_ENV=production

# Port the app is reachable on (open http://<plant-pc-ip>:8000 from any device on the network)
APP_PORT=8000

# Browser origins allowed to call the API (CORS). The default "*" keeps the API
# open to any device on the plant LAN. If you ever expose this app beyond the
# local network, set an explicit comma-separated allow-list, e.g.
#   CORS_ORIGINS=https://plant.golden.com.fj,https://10.0.0.5:8000
# Note: credentialed CORS requests are only enabled when an explicit list is set
# (a "*" origin cannot be combined with credentials per the CORS spec).
CORS_ORIGINS=*

# Database password (used internally between the app and Postgres).
# Pick a long, random value. In production the app warns on known weak/example
# passwords (e.g. fmp_password). Do not ship the example value.
DB_PASSWORD=change_this_db_password

# Secret used to sign login tokens — MUST be long and random.
# In production the app REFUSES TO START if this is a known placeholder
# (e.g. "change_this_to_a_long_random_string", "change-me-...") or under 32 chars.
# Generate a strong one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_this_to_a_long_random_string

# First-run administrator account. You'll be asked to change this password on
# first login — do not leave it as the example value. The app warns on weak
# defaults such as "admin123".
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Active Directory (LDAP) ────────────────────────────────────────────────
# Set AD_ENABLED=true once you confirm your DC is reachable from this server.
# Staff then log in with their Windows username + password.
# The local admin account always uses the password above regardless of this setting.
#
AD_ENABLED=false
AD_SERVER=192.168.1.10          # IP or hostname of your domain controller
AD_DOMAIN=golden.com.fj         # your AD domain (used to build user@domain for LDAP bind)
AD_BASE_DN=DC=golden,DC=com,DC=fj  # base DN — required for the group-to-role mapping below
AD_LOCAL_BYPASS=admin           # comma-separated accounts that always use local passwords

# ── AD group → app role mapping (optional) ─────────────────────────────────
# Map Active Directory security groups to dashboard roles. On every AD login the
# app reads the user's group memberships (under AD_BASE_DN) and sets their role
# to the HIGHEST matching role below — so AD promotions/demotions apply
# automatically. Format: comma-separated "GroupCN=role" pairs. Roles are one of:
# operator, supervisor, manager, admin. Leave BLANK to keep the current
# behaviour (new AD users are auto-provisioned as operator; roles managed in-app).
AD_GROUP_ROLE_MAP=
# Example:
# AD_GROUP_ROLE_MAP=Fibre-Admins=admin,Fibre-Managers=manager,Fibre-Supervisors=supervisor,Fibre-Operators=operator
#
# When true (and AD_GROUP_ROLE_MAP is set): an AD user in NONE of the mapped
# groups is DENIED access (their account is deactivated). When false, an unmapped
# AD user keeps their existing role/access. Keep false unless you want strict
# group-gated access.
AD_GROUP_STRICT=false

# ── Login lockout (brute-force protection) ─────────────────────────────────
# After LOCKOUT_THRESHOLD consecutive failed logins a known account is locked
# for LOCKOUT_MINUTES, then auto-unlocks. Defaults shown; usually leave as-is.
# LOCKOUT_THRESHOLD=5
# LOCKOUT_MINUTES=15

# ── Scheduler (automation) ─────────────────────────────────────────────────
# In-process background scheduler for the daily alert scan and the scheduled
# report email. ON by default. IMPORTANT: this app runs ONE uvicorn worker, so
# exactly one scheduler runs. If you ever scale to multiple workers/replicas,
# set SCHEDULER_ENABLED=false on all but ONE so jobs don't run multiple times.
# SCHEDULER_ENABLED=true
# Hour (0-23, UTC) the daily alert scan runs.
# ALERT_SCAN_HOUR=6

# ── Alerts / thresholds ────────────────────────────────────────────────────
# Proactive alerts are generated automatically and shown in the dashboard; no
# config is required. These thresholds default to the same values the dashboard
# "insights" already use — override only if you want different watch lines.
# ALERT_HEAVY_DOWNTIME_MIN=240     # a single day losing >= this many minutes -> critical
# ALERT_DOWNTIME_PCT=12            # period downtime % of scheduled at/above this -> warn
# ALERT_FUEL_EFF_MULT=1.4          # a day worse than this x the avg L/1k trays -> warn
# ALERT_LOW_OUTPUT_FRAC=0.6        # a day below this fraction of the avg/day -> warn
# ALERT_REJECT_PCT=4               # period reject/re-pulp % at/above this -> warn
# ALERT_WINDOW_DAYS=14             # trailing days each scan considers
# ALERT_MISSED_SHIFT_GRACE_DAYS=1  # only flag missing days older than this (late entry)
# ALERT_EXPECTED_SHIFTS_PER_DAY=1  # minimum shift entries expected per day

# ── Email / SMTP (Microsoft 365 / Exchange) ────────────────────────────────
# DEFAULT OFF. Nothing is emailed until you set SMTP_ENABLED=true AND fill in
# host/from/recipients below. The app runs fine with these left as-is.
# TO ENABLE alert + report emails, set ALL of:
# SMTP_ENABLED=true
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=fmp-alerts@golden.com.fj       # mailbox to authenticate as
# SMTP_PASSWORD=                            # that mailbox's password / app password
# SMTP_FROM=fmp-alerts@golden.com.fj        # usually = SMTP_USER
# SMTP_USE_STARTTLS=true
# ALERT_EMAIL_TO=manager@golden.com.fj,supervisor@golden.com.fj   # warn/critical alerts
# REPORT_EMAIL_TO=manager@golden.com.fj                            # scheduled report
# ALERT_EMAIL_COOLDOWN_MIN=720             # don't re-email the same alert within 12h

# ── Scheduled report email ─────────────────────────────────────────────────
# Builds the production report (.xlsx) for the prior period and emails it to
# REPORT_EMAIL_TO. Requires email configured above; if SMTP is off it just logs
# and skips. Cadence: monthly (1st of month, prior month), weekly (Mon, prior 7
# days), or off.
# REPORT_EMAIL_CADENCE=monthly
# REPORT_EMAIL_HOUR=7              # hour (0-23, UTC) the job runs
# REPORT_EMAIL_DAY_OF_MONTH=1      # day-of-month for the monthly cadence

# ── AI assistant (Anthropic Claude) ────────────────────────────────────────
# DEFAULT OFF. Powers the AI "Plant Manager's Commentary" in the Month End
# Report and the "Ask the plant data" panel. When on, aggregated monthly figures
# (never raw shift rows) are sent to Anthropic's API, so it stays off until you
# opt in AND set a key. Get a key at https://console.anthropic.com/.
# AI_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-opus-4-8          # default; any current Claude model id

# ── Database backups (db-backup sidecar) ───────────────────────────────────
# The db-backup service runs pg_dump nightly into ./backups on this PC and
# prunes old dumps by the retention below. It uses DB_PASSWORD above. Defaults
# shown — usually leave as-is.
# BACKUP_KEEP_DAYS=7
# BACKUP_KEEP_WEEKS=4
# BACKUP_KEEP_MONTHS=6
#
# OFF-BOX COPY (IMPORTANT — a backup on the same disk is not a real backup):
#   Create a Windows Task Scheduler task to copy ./backups to a network share or
#   OneDrive nightly, e.g.:
#     robocopy "<repo>\backups" "\\NAS\fmp-backups" /MIR /R:2 /W:5
#     robocopy "<repo>\backups" "%OneDrive%\fmp-backups" /MIR /R:2 /W:5
#
# RESTORE a dump into the running db container:
#   gunzip -c "backups/daily/fmp-YYYYMMDD-HHMMSS.sql.gz" | \
#     docker exec -i fmp-app-db-1 psql -U fmp -d fmp
#   (stop the app container first; restore into a clean/empty database.)

# ── Power BI / BI reporting (read-only views) ──────────────────────────────
# A migration creates four read-only views (vw_daily_production, vw_deliveries,
# vw_fuel, vw_downtime) and a NOLOGIN role `fmp_readonly` with SELECT on them.
# These views are the STABLE BI CONTRACT and exclude soft-deleted rows. There is
# NO env var here on purpose — the read-only password is set OUT OF BAND, once:
#   docker compose exec db psql -U fmp -d fmp \
#     -c "ALTER ROLE fmp_readonly WITH LOGIN PASSWORD 'choose-a-strong-password';"
# To let Power BI on another PC reach Postgres over the LAN, publish the db port
# (add  ports: ["5432:5432"]  to the db service in docker-compose.yml) and allow
# it through the Windows firewall on the local subnet ONLY (never the internet).
# Then point Power BI's PostgreSQL connector at <plant-pc-ip>:5432, database fmp,
# user fmp_readonly, and select the vw_* views. See README "Power BI / BI
# reporting".
