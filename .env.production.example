# =============================================================================
# PRODUCTION .env — Fibre Mold Plant (LAN, HTTPS via Caddy)
# -----------------------------------------------------------------------------
# 1. Copy this file to ".env":            Copy-Item .env.production.example .env
# 2. Fill in the 5 REQUIRED values below (search for "<<< SET").
# 3. Start (HTTPS):  docker compose --profile tls up -d --build
#
# The app runs APP_ENV=production and is FAIL-CLOSED: it REFUSES TO START until
# SECRET_KEY is a real value (>= 32 chars, not this placeholder). docker compose
# also aborts if any REQUIRED value is missing. That is intentional — the plant
# never runs on guessable defaults.
#
# For the FULL list of optional settings (AD login, email, AI, alert thresholds,
# backup retention, Power BI), see .env.example.
# =============================================================================

APP_ENV=production

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# How clients reach the server, used by the Caddy HTTPS proxy. For a LAN/IP box
# use its https URL (Caddy issues a self-signed cert from its internal CA).
SITE_ADDRESS=https://192.168.1.50            # <<< SET to your server's LAN IP

# Signs login tokens. MUST be long + random and unique to THIS server.
# Generate one:  docker run --rm python:3.12-slim python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_ME__run_the_generate_command_above   # <<< SET (app won't start until you do)

# Internal Postgres password (any long random string; clients never see it).
DB_PASSWORD=REPLACE_ME__long_random_password            # <<< SET

# First administrator account. You'll be forced to change this password on first
# login — still, don't ship a weak one.
ADMIN_USERNAME=admin                                    # <<< SET (or keep 'admin')
ADMIN_PASSWORD=REPLACE_ME__strong_admin_password        # <<< SET

# ── Optional (safe defaults; uncomment only to change) ───────────────────────

# CORS: same-origin behind Caddy, so the default is fine. Only matters if some
# other origin must call the API directly.
# CORS_ORIGINS=*

# Plain-HTTP port. UNUSED in HTTPS-only mode (the app port isn't published).
# APP_PORT=8000

# Active Directory login (staff use Windows credentials). See .env.example.
# AD_ENABLED=true
# AD_SERVER=192.168.1.10
# AD_DOMAIN=golden.com.fj
# AD_BASE_DN=DC=golden,DC=com,DC=fj

# Email alerts + scheduled report (off until SMTP is configured). See .env.example.
# SMTP_ENABLED=true

# AI assistant / Month-End commentary (off until a key is set). See .env.example.
# AI_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-...

# Nightly backups go to ./backups by default (retention 7d/4w/6m). See .env.example
# for retention + the off-box copy reminder.
